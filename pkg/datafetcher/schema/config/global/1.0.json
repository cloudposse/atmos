    "spacelift": {
      "title": "spacelift",
      "description": "Spacelift section",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^!include"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "workspace_enabled": {
              "type": "boolean"
            },
            "stack_destructor_enabled": {
              "type": "boolean"
            },
            "protect_from_deletion": {
              "type": "boolean"
            },
            "autodeploy": {
              "type": "boolean"
            },
            "terraform_version": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string"
                }
              ]
            }
          },
          "required": []
        }
      ]
    },
    "atlantis": {
      "title": "atlantis",
      "description": "Atlantis section",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^!include"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "config_template_name": {
              "type": "string"
            },
            "config_template": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^!include"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "project_template_name": {
              "type": "string"
            },
            "project_template": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^!include"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "workflow_templates": {
              "oneOf": [
