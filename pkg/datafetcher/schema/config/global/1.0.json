        },
        {
          "type": "object",
          "patternProperties": {
            "^[/a-zA-Z0-9-_{}. ]+$": {
              "$ref": "#/definitions/depends_on_manifest"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "depends_on_manifest": {
      "title": "depends_on_manifest",
      "description": "Depends_on manifest",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^!include"
        },
        {
          "type": "object",
          "properties": {
            "namespace": {
              "type": "string"
            },
            "tenant": {
              "type": "string"
            },
            "environment": {
              "type": "string"
            },
            "stage": {
              "type": "string"
            },
            "component": {
              "type": "string"
            },
            "file": {
              "type": "string"
            },
            "folder": {
              "type": "string"
            }
          },
          "oneOf": [
            {
              "required": [
                "component"
              ]
            },
            {
              "required": [
                "file"
              ]
            },
            {
              "required": [
