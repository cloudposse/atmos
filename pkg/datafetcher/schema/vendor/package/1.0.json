{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Atmos Vendor Config",
    "description": "Schema for Atmos vendoring manifest",
    "fileMatch": [
        "vendor.{yml,yaml}",
        "vendor.d/**/*.{yml,yaml}"
    ],
    "type": "object",
    "properties": {
      "apiVersion": {
        "type": "string",
        "enum": ["atmos/v1"],
        "description": "API version of the Atmos configuration"
      },
      "kind": {
        "type": "string",
        "enum": ["AtmosVendorConfig"],
        "description": "The type of configuration, must be AtmosVendorConfig"
      },
      "metadata": {
        "type": "object",
        "description": "Metadata for the vendoring configuration",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the vendoring configuration"
          },
          "description": {
            "type": "string",
            "description": "Description of the vendoring configuration"
          }
        },
        "required": ["name", "description"]
      },
      "spec": {
        "type": "object",
        "description": "Specification of the vendoring configuration",
        "properties": {
          "base_path": {
            "type": "string",
            "description": "Path to vendor file or directory, can be relative"
          },
          "imports": {
            "type": "array",
            "description": "List of imports for the vendoring configuration",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "description": "List of sources for the vendoring configuration",
            "items": {
              "type": "object",
              "properties": {
                "component": {
                  "type": "string",
                  "description": "Name of the component"
                },
                "source": {
                  "type": "string",
                  "description": "Source URL for the component. Supports Git, HTTP, S3, etc."
                },
                "version": {
                  "type": "string",
                  "description": "Version of the component to fetch. Either an exact tag/commit/branch, or a semver-range expression (e.g. ^1.0.0, ~1.2.3, >=1.0.0 <2.0.0) resolved against the source's Git tags; the first resolution is recorded in vendor.lock.yaml and reused on later pulls until the range changes or --refresh-lock is passed."
                },
                "targets": {
                  "type": "array",
                  "description": "List of target paths where the component will be vendored. Each target can be a simple string path or an object with 'path' and optional 'version' override.",
                  "items": {
                    "oneOf": [
                      {
                        "type": "string",
                        "description": "Target path (supports Go template syntax with {{.Version}}, {{.Component}})"
                      },
                      {
                        "type": "object",
                        "description": "Target with optional version override",
                        "properties": {
                          "path": {
                            "type": "string",
                            "description": "Target path (supports Go template syntax with {{.Version}}, {{.Component}})"
                          },
                          "version": {
                            "type": "string",
                            "description": "Version override for this target. Overrides the source-level version for both the source URL and target path templates. Accepts the same exact-pin or semver-range syntax as the source-level version."
                          }
                        },
                        "required": ["path"],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "included_paths": {
                  "type": "array",
                  "description": "Glob patterns for files to include",
                  "items": {
                    "type": "string"
                  }
                },
                "excluded_paths": {
                  "type": "array",
                  "description": "Glob patterns for files to exclude",
                  "items": {
                    "type": "string"
                  }
                },
                "tags": {
                  "type": "array",
                  "description": "Tags associated with the component",
                  "items": {
                    "type": "string"
                  }
                },
                "constraints": {
                  "type": "object",
                  "description": "Controls which upstream versions 'atmos vendor update' may select for this source",
                  "properties": {
                    "version": {
                      "type": "string",
                      "description": "Semantic version constraint (e.g. ^1.0.0, ~1.2.3, >=1.0.0 <2.0.0)"
                    },
                    "excluded_versions": {
                      "type": "array",
                      "description": "Versions to exclude; supports exact values and wildcard patterns (e.g. 1.5.*)",
                      "items": {
                        "type": "string"
                      }
                    },
                    "no_prereleases": {
                      "type": "boolean",
                      "default": false,
                      "description": "Exclude pre-release versions (alpha, beta, rc)"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": ["component", "source", "version", "targets"]
            }
          }
        },
        "required": ["sources"]
      }
    },
    "required": ["apiVersion", "kind", "metadata", "spec"]
  }
