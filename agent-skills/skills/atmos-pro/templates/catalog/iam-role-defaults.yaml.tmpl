# stacks/catalog/aws/iam-role/defaults.yaml
#
# Abstract base for Atmos Pro IAM roles with GitHub OIDC trust.
# Defaults to main-branch-only scope; concrete roles may override.

components:
  terraform:
    aws/iam-role/defaults:
      metadata:
        type: abstract
        component: aws/iam-role
      vars:
        enabled: true
        github_oidc_provider_enabled: true
        github_oidc_provider_arn: !terraform.state github-oidc-provider oidc_provider_arn
        trusted_github_org: {{ .org }}
        trusted_github_repos:
          - "{{ .org }}/{{ .repo }}:main"
