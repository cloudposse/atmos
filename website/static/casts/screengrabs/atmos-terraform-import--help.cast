[0.000003875,"o","\u001b[1;38;2;0;163;224mCOMPATIBILITY FLAGS\u001b[0m\n"]
[0.000001042,"o","\n"]
[0.000001667,"o","  These flags are passed through to the underlying terraform/tofu command.\n"]
[9.58e-7,"o","\n"]
[0.000009458,"o","      \u001b[38;2;73;85;104m-allow-missing-config\u001b[0m  \u001b[38;2;255;255;255mAllow import when no resource configuration block exists\u001b[0m\n"]
[0.0000065,"o","      \u001b[38;2;73;85;104m-compact-warnings\u001b[0m      \u001b[38;2;255;255;255mShow warnings in a more compact form\u001b[0m\n"]
[0.000007292,"o","      \u001b[38;2;73;85;104m-config\u001b[0m                \u001b[38;2;255;255;255mPath to directory of Terraform configuration files\u001b[0m\n"]
[0.00001675,"o","      \u001b[38;2;73;85;104m-input\u001b[0m                 \u001b[38;2;255;255;255mAsk for input for variables if not directly set (default:\u001b[0m\n"]
[0.000003458,"o","                             \u001b[38;2;255;255;255mtrue)\u001b[0m\n"]
[0.000010417,"o","      \u001b[38;2;73;85;104m-lock\u001b[0m                  \u001b[38;2;255;255;255mLock the state file when locking is supported (default: true)\u001b[0m\n"]
[0.000006958,"o","      \u001b[38;2;73;85;104m-lock-timeout\u001b[0m          \u001b[38;2;255;255;255mDuration to retry a state lock (default: 0s)\u001b[0m\n"]
[0.000006709,"o","      \u001b[38;2;73;85;104m-no-color\u001b[0m              \u001b[38;2;255;255;255mDisable color output in the command output\u001b[0m\n"]
[0.00000725,"o","      \u001b[38;2;73;85;104m-parallelism\u001b[0m           \u001b[38;2;255;255;255mLimit the number of concurrent operations (default: 10)\u001b[0m\n"]
[0.000006541,"o","      \u001b[38;2;73;85;104m-refresh\u001b[0m               \u001b[38;2;255;255;255mUpdate state prior to checking for differences (default:\u001b[0m\n"]
[0.000003084,"o","                             \u001b[38;2;255;255;255mtrue)\u001b[0m\n"]
[0.000006375,"o","      \u001b[38;2;73;85;104m-state\u001b[0m                 \u001b[38;2;255;255;255mPath to read and save state\u001b[0m\n"]
[0.000005666,"o","      \u001b[38;2;73;85;104m-state-out\u001b[0m             \u001b[38;2;255;255;255mPath to write updated state\u001b[0m\n"]
[0.000007209,"o","      \u001b[38;2;73;85;104m-target\u001b[0m                \u001b[38;2;255;255;255mTarget specific resources for planning/applying\u001b[0m\n"]
[0.000006666,"o","      \u001b[38;2;73;85;104m-var\u001b[0m                   \u001b[38;2;255;255;255mSet a value for one of the input variables\u001b[0m\n"]
[0.000006167,"o","      \u001b[38;2;73;85;104m-var-file\u001b[0m              \u001b[38;2;255;255;255mLoad variable values from the given file\u001b[0m\n"]
[0.00000125,"o","\n"]
[0.001546125,"o","\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mUse \u001b[0m\u001b[38;2;0;255;255;1m--help=usage\u001b[0m\u001b[38;2;247;250;252m for examples or \u001b[0m\u001b[38;2;0;255;255;1m--help=all\u001b[0m\u001b[38;2;247;250;252m for all flags and full\u001b[0m\u001b[38;2;247;250;252m help.\u001b[0m\u001b[0m\n"]
