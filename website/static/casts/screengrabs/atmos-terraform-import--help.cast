[0.000006167,"o","\u001b[1;38;2;0;163;224mCOMPATIBILITY FLAGS\u001b[0m\n"]
[7.92e-7,"o","\n"]
[0.000001208,"o","  These flags are passed through to the underlying terraform/tofu command.\n"]
[0.000001542,"o","\n"]
[0.000010583,"o","      \u001b[38;2;73;85;104m-allow-missing-config\u001b[0m  \u001b[38;2;255;255;255mAllow import when no resource configuration block exists\u001b[0m\n"]
[0.000005292,"o","      \u001b[38;2;73;85;104m-compact-warnings\u001b[0m      \u001b[38;2;255;255;255mShow warnings in a more compact form\u001b[0m\n"]
[0.000045583,"o","      \u001b[38;2;73;85;104m-config\u001b[0m                \u001b[38;2;255;255;255mPath to directory of Terraform configuration files\u001b[0m\n"]
[0.000006167,"o","      \u001b[38;2;73;85;104m-input\u001b[0m                 \u001b[38;2;255;255;255mAsk for input for variables if not directly set (default:\u001b[0m\n"]
[0.000002666,"o","                             \u001b[38;2;255;255;255mtrue)\u001b[0m\n"]
[0.000005459,"o","      \u001b[38;2;73;85;104m-lock\u001b[0m                  \u001b[38;2;255;255;255mLock the state file when locking is supported (default: true)\u001b[0m\n"]
[0.000004875,"o","      \u001b[38;2;73;85;104m-lock-timeout\u001b[0m          \u001b[38;2;255;255;255mDuration to retry a state lock (default: 0s)\u001b[0m\n"]
[0.000004875,"o","      \u001b[38;2;73;85;104m-no-color\u001b[0m              \u001b[38;2;255;255;255mDisable color output in the command output\u001b[0m\n"]
[0.000005,"o","      \u001b[38;2;73;85;104m-parallelism\u001b[0m           \u001b[38;2;255;255;255mLimit the number of concurrent operations (default: 10)\u001b[0m\n"]
[0.000005875,"o","      \u001b[38;2;73;85;104m-refresh\u001b[0m               \u001b[38;2;255;255;255mUpdate state prior to checking for differences (default:\u001b[0m\n"]
[0.000002,"o","                             \u001b[38;2;255;255;255mtrue)\u001b[0m\n"]
[0.000004166,"o","      \u001b[38;2;73;85;104m-state\u001b[0m                 \u001b[38;2;255;255;255mPath to read and save state\u001b[0m\n"]
[0.000004209,"o","      \u001b[38;2;73;85;104m-state-out\u001b[0m             \u001b[38;2;255;255;255mPath to write updated state\u001b[0m\n"]
[0.000005458,"o","      \u001b[38;2;73;85;104m-target\u001b[0m                \u001b[38;2;255;255;255mTarget specific resources for planning/applying\u001b[0m\n"]
[0.000006167,"o","      \u001b[38;2;73;85;104m-var\u001b[0m                   \u001b[38;2;255;255;255mSet a value for one of the input variables\u001b[0m\n"]
[0.000005083,"o","      \u001b[38;2;73;85;104m-var-file\u001b[0m              \u001b[38;2;255;255;255mLoad variable values from the given file\u001b[0m\n"]
[7.08e-7,"o","\n"]
[0.002573875,"o","\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mUse \u001b[0m\u001b[38;2;0;255;255;1m--help=usage\u001b[0m\u001b[38;2;247;250;252m for examples or \u001b[0m\u001b[38;2;0;255;255;1m--help=all\u001b[0m\u001b[38;2;247;250;252m for all flags and full\u001b[0m\u001b[38;2;247;250;252m help.\u001b[0m\u001b[0m\n"]
