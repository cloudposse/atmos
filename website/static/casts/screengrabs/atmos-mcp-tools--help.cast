[0.006756167,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mConnect to an external MCP server and list its available\u001b[0m\u001b[38;2;247;250;252m tools.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThis starts the MCP server subprocess, performs the MCP initialization\u001b[0m\u001b[38;2;247;250;252m handshake,\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mretrieves the tool list, then shuts down the\u001b[0m\u001b[38;2;247;250;252m server.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mExamples:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# List tools from an AWS EKS MCP server.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp tools aws-eks\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Example output:\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# TOOL                    DESCRIPTION\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# list_clusters           List EKS clusters in the account\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# describe_cluster        Get details of an EKS cluster\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# list_nodegroups         List node groups for a cluster\u001b[0m\u001b[38;5;231m\u001b[0m\n"]
