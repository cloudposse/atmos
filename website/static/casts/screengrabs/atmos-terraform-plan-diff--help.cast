[0.002114583,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mCompare two Terraform plans and show the differences between\u001b[0m\u001b[38;2;247;250;252m them.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mIt takes an original plan file (--orig) and optionally a new plan file \u001b[0m\u001b[38;2;247;250;252m(--new). \u001b[0m\u001b[38;2;247;250;252mIf the\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m  \u001b[38;2;247;250;252mnew\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mplan file is not provided, it will generate one by running 'terraform\u001b[0m\u001b[38;2;247;250;252m plan' \u001b[0m\u001b[38;2;247;250;252mwith the\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mcurrent\u001b[0m\u001b[38;2;247;250;252m configuration.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe command shows differences in variables, resources, and outputs between the two\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mplans.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mExample\u001b[0m\u001b[38;2;247;250;252m usage: \u001b[0m\u001b[38;2;247;250;252matmos terraform plan-diff myapp -s dev\u001b[0m\u001b[38;2;247;250;252m --orig=orig.plan \u001b[0m\u001b[38;2;247;250;252matmos terraform\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mplan-diff myapp -s dev --orig=orig.plan\u001b[0m\u001b[38;2;247;250;252m --new=new.plan\u001b[0m\n"]
