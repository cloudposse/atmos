[0.004517959,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mStart the Atmos Language Server Protocol (LSP)\u001b[0m\u001b[38;2;247;250;252m server.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe LSP server enables IDE integration for Atmos stack files,\u001b[0m\u001b[38;2;247;250;252m providing:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mSyntax validation and\u001b[0m\u001b[38;2;247;250;252m diagnostics\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mAuto-completion for Atmos keywords and\u001b[0m\u001b[38;2;247;250;252m components\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mHover documentation for Atmos-specific\u001b[0m\u001b[38;2;247;250;252m syntax\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mGo to definition for stack\u001b[0m\u001b[38;2;247;250;252m references\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe server can use different\u001b[0m\u001b[38;2;247;250;252m transports:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mstdio: Standard input/output (default, for IDE\u001b[0m\u001b[38;2;247;250;252m integration)\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mtcp: TCP server (for remote\u001b[0m\u001b[38;2;247;250;252m connections)\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mтАв \u001b[0m\u001b[38;2;247;250;252mwebsocket: WebSocket server (for web-based\u001b[0m\u001b[38;2;247;250;252m editors)\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mExample usage with VS\u001b[0m\u001b[38;2;247;250;252m Code: \u001b[0m\u001b[38;2;247;250;252mConfigure your editor's LSP client to\u001b[0m\u001b[38;2;247;250;252m run: \u001b[0m\u001b[38;2;247;250;252matmos lsp start\u001b[0m\u001b[38;2;247;250;252m --\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mtransport=stdio\u001b[0m\n"]
