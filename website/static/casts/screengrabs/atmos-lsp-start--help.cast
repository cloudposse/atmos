0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPaths to search for Atmos configuration (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --force-color\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mForce color output even when not a TTY (useful for\u001b[0m\u001b[38;2;255;255;255m screenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --force-tty\u001b[0m                            \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mForce TTY mode with sane defaults when terminal detection fails \u001b[0m\u001b[38;2;255;255;255m(useful\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mfor\u001b[0m\u001b[38;2;255;255;255m screenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap\u001b[0m                              \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mShow performance heatmap visualization after command execution \u001b[0m\u001b[38;2;255;255;255m(includes\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mP95\u001b[0m\u001b[38;2;255;255;255m latency)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap-mode\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mHeatmap visualization mode: bar, sparkline, table (press 1-3 to switch\u001b[0m\u001b[38;2;255;255;255m in\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mTUI) (default \u001b[0m\u001b[38;2;155;81;224;1mbar\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --identity\u001b[0m \u001b[90mstring\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mIdentity to use for authentication. Use --identity to select interactively,\u001b[0m\u001b[38;2;255;255;255m --\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255midentity=NAME to\u001b[0m\u001b[38;2;255;255;255m specify\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --interactive\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable interactive prompts for missing required flags, optional\u001b[0m\u001b[38;2;255;255;255m value\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mflags using the sentinel pattern, and missing positional\u001b[0m\u001b[38;2;255;255;255m arguments\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m(requires TTY, disabled in CI) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-file\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mThe file to write Atmos logs to. Logs can be written to any file or\u001b[0m\u001b[38;2;255;255;255m any\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstandard file descriptor, including '/dev/stdout', '/dev/stderr'\u001b[0m\u001b[38;2;255;255;255m and\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m'/dev/null' (default \u001b[0m\u001b[38;2;155;81;224;1m/dev/stderr\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-level\u001b[0m \u001b[90mstring\u001b[0m                    \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mLogs level. Supported log levels are Trace, Debug, Info, Warning, Off.\u001b[0m\u001b[38;2;255;255;255m If\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mthe log level is set to Off, Atmos will not log any messages \u001b[0m\u001b[38;2;255;255;255m(default\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;155;81;224;1mWarning\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --mask\u001b[0m                                 \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable automatic masking of sensitive data in output (use --mask=false\u001b[0m\u001b[38;2;255;255;255m to\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mdisable) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --no-color\u001b[0m                             \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mDisable color\u001b[0m\u001b[38;2;255;255;255m output\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --pager\u001b[0m \u001b[90mstring\u001b[0m                         \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable pager for output (--pager or --pager=true to enable, --pager=false\u001b[0m\u001b[38;2;255;255;255m to\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mdisable, --pager=less to use specific\u001b[0m\u001b[38;2;255;255;255m pager)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile\u001b[0m \u001b[90mstrings\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mActivate configuration profiles (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile-file\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mWrite profiling data to file instead of starting\u001b[0m\u001b[38;2;255;255;255m server\u001b[0m\u001b[0