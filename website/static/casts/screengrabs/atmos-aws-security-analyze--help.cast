38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --severity critical,high\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Filter by source service\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --source security-hub\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Output as JSON for CI/CD integration\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --format json\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Enable AI-powered analysis\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u