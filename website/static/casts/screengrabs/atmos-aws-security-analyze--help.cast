[0.010325416,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAnalyze AWS security findings and map them to Atmos components and\u001b[0m\u001b[38;2;247;250;252m stacks.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mConnects to AWS Security Hub, Config, Inspector, GuardDuty, and other security\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mservices via Atmos\u001b[0m\u001b[38;2;247;250;252m Auth, \u001b[0m\u001b[38;2;247;250;252mmaps findings to the Terraform/Atmos components that manage\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mthe affected resources, and\u001b[0m\u001b[38;2;247;250;252m generates \u001b[0m\u001b[38;2;247;250;252mremediation reports with concrete code\u001b[0m\u001b[38;2;247;250;252m changes.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1m## \u001b[0m\u001b[38;2;247;250;252;1mExamples\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Analyze findings for a specific stack\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Filter by severity\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --severity critical,high\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Filter by source service\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --source security-hub\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Output as JSON for CI/CD integration\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m$ atmos aws security analyze --stack prod-us-east-1 --format json\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Enable AI-powered analysis\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u