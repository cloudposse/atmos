1b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Launch shell in default instance\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mgeodesic\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                               \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Launch shell in named instance\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mterraform\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--instance\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44malice\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                             \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Launch shell with custom instance name\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                          \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mgeodesic\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--instance\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mprod\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                               \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Create a new auto-numbered instance (starts new container with unique name)\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                     \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mgeodesic\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--new\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                         \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44mThis creates a new instance named \"default-1\", \"default-2\", etc. based on the --instance flag (default \"default\").\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Create a new auto-numbered instance with custom base name\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mgeodesic\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--instance\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44malice\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--new\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                        \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44mThis creates \"alice-1\", \"alice-2\", etc.\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                           \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Rebuild existing instance and attach (destroys and recreates container)\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                         \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mterraform\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--replace\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                    \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44mThis rebuilds the \"default\" instance (or use --instance to specify which one).\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                    \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Launch shell and remove container on exit (like 'docker run --rm')\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                              \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mdevcontainer\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mshell\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mgeodesic\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--rm\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                          \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                                                  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44mThe container will be automatically removed when you exit the shell.\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                              \u001b[0m\n  \u001b[44m                                                                                                                      \u001b[0m\n\n\u001b[1;36mFLAGS\u001b[0m\n\n  \u001b[1;36m-h, --help\u001b[0m             \u00