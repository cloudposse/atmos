creenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --force-tty\u001b[0m                            \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mForce TTY mode with sane defaults when terminal detection fails \u001b[0m\u001b[38;2;255;255;255m(useful\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mfor\u001b[0m\u001b[38;2;255;255;255m screenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap\u001b[0m                              \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mShow performance heatmap visualization after command execution \u001b[0m\u001b[38;2;255;255;255m(includes\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mP95\u001b[0m\u001b[38;2;255;255;255m latency)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap-mode\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mHeatmap visualization mode: bar, sparkline, table (press 1-3 to switch\u001b[0m\u001b[38;2;255;255;255m in\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mTUI) (default \u001b[0m\u001b[38;2;155;81;224;1mbar\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-i, --identity\u001b[0m \u001b[90mstring\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mIdentity to use when accessing the secret\u001b[0m\u001b[38;2;255;255;255m backend\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --interactive\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable interactive prompts for missing required flags, optional\u001b[0m\u001b[38;2;255;255;255m value\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mflags using the sentinel pattern, and missing positional\u001b[0m\u001b[38;2;255;255;255m arguments\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m(requires TTY, disabled in CI) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-file\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mThe file to write Atmos logs to. Logs can be written to any file or\u001b[0m\u001b[38;2;255;255;255m any\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstandard file descriptor, including '/dev/stdout', '/dev/stderr'\u001b[0m\u001b[38;2;255;255;255m and\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m'/dev/null' (default \u0