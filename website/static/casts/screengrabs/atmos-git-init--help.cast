0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;247;250;252mWith --keep-history: the source's full history is preserved and the\u001b[0m\u001b[38;2;247;250;252m source\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mstays reachable as the 'upstream' remote, so future updates can be\u001b[0m\u001b[38;2;247;250;252m pulled.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe seed source can also be configured per repository\u001b[0m\u001b[38;2;247;250;252m under \u001b[0m\u001b[38;2;247;250;252mgit.repositories.\u001b[0m\u001b[38;2;247;250;252m.init\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m(from, keep_\u001b[0m\u001b[38;2;247;250;252mhistory); the --from and\u001b[0m\u001b[38;2;247;250;252m --keep-history \u001b[0m\u001b[38;2;247;250;252mflags override the configured\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m  \u001b[38;2;247;250;252mdefaults.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mWhen no argument is provided, Atmos initializes the single configured\u001b[0m\u001b[38;2;247;250;252m repository.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mArguments after -- are passed verbatim to the underlying git\u001b[0m\u001b[38;2;247;250;252m invocation \u001b[0m\u001b[38;2;247;250;252m(git init, or\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mthe git clone of\u001b[0m\u001b[38;2;247;250;252m --from): \u001b[0m\u001b[38;2;247;250;252matmos git init flux-deploy --\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mfrom=https://github.com/acme/template.git --\u00