 to enable, --pager=false\u001b[0m\u001b[38;2;255;255;255m to\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mdisable, --pager=less to use specific\u001b[0m\u001b[38;2;255;255;255m pager)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile\u001b[0m \u001b[90mstrings\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mActivate configuration profiles (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile-file\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mWrite profiling data to file instead of starting\u001b[0m\u001b[38;2;255;255;255m server\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile-type\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mType of profile to collect when using --profile-file. Options: cpu,\u001b[0m\u001b[38;2;255;255;255m heap,\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mallocs, goroutine, block, mutex, threadcreate, trace (default \u001b[0m\u001b[38;2;155;81;224;1mcpu\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profiler-enabled\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable pprof profiling\u001b[0m\u001b[38;2;255;255;255m server\