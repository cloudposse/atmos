rged in Atmos stack manifests (replace, append,\u001b[0m\u001b[38;2;255;255;255m merge)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --skill\u001b[0m \u001b[90mstrings\u001b[0m                        \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mSpecify skills for AI analysis context (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag,\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mrequires\u001b[0m\u001b[38;2;255;255;255m --ai)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --use-version\u001b[0m \u001b[90mstring\u001b[0m                   \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mUse a specific version of Atmos (e.g.,\u001b[0m\u001b[38;2;255;255;255m --use-version=1.160.0)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-v, --verbose\u001b[0m                              \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable verbose error output with full context, stack traces, and\u001b[0m\u001b[38;2;255;255;255m detailed\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255minformation\u001b[0m\u001b[0m\n\n\n\u001b[1;36mCOMPATIBILITY FLAGS\u001b[0m\n\n  These flags are passed through to the underlying terraform/tofu command.\n\n      \u001b[90m-chdir\u001b[0m    \u001b[97mSwitch to a different working directory before executing the given subcommand\u001b[0m\n      \u001b[90m-help\u001b[0m     \u001b[97mShow terraform help output\u001b[0m\n      \u001b[90m-version\u001b[0m  \u001b[97mShow terrafor