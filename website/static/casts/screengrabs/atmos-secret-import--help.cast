[0.0021265,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mImport is the general way to bring existing secret values under\u001b[0m\u001b[38;2;247;250;252m management.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mWith a FILE (.env or JSON, or - for stdin), each key is written to the backend named\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m  \u001b[38;2;247;250;252min\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mits declaration (the \u001b[0m\u001b[38;2;0;255;255;1mstore:\u001b[0m\u001b[38;2;247;250;252m or \u001b[0m\u001b[38;2;0;255;255;1msops:\u001b[0m\u001b[38;2;247;250;252m of the matching secrets.vars entry) — keys backed\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mby different stores/providers are routed automatically. Declared keys are set;\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mundeclared keys are warned about and skipped (unlike \u001b[0m\u001b[38;2;0;255;255;1mpush\u001b[0m\u001b[38;2;247;250;252m, which\u001b[0m\u001b[38;2;247;250;252m fails).\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mWith a NAME and any --from-*\u001b[0m\u001b[38;2;247;250;252m flag, the value is copied from an existing store\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m  \u001b[38;2;247;250;252mcoordinate\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252minto the declaration's computed coordinate (like \u001b[0m\u001b[38;2;0;255;255;1mterraform import\u001b[0m\u001b[38;2;247;250;252m, the source is never\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mmodified or deleted). The --from-stack/--from-component values are raw path segments —\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mtypically transcribed from a legacy \u001b[0m\u001b[38;2;0;255;255;1m!store \u003cstore\u003e \u003cstack\u003e \u003ccomponent\u003e \u003ckey\u003e\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mexpression — and need not name a real stack or component. --from-store defaults to the\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mdeclaration's own store, --from-key to the secret\u001b[0m\u001b[38;2;247;250;252m name.\u001b[0m\n"]
