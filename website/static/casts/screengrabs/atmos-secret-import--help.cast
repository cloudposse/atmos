01b[38;2;247;250;252mentry) — keys backed by different stores/providers are routed automatically.\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mDeclared keys are set; undeclared keys are warned about and skipped (unlike\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m  \u001b[38;2;0;255;255;1mpush\u001b[0m\u001b[38;2;247;250;252m, which\u001b[0m\u001b[38;2;247;250;252m fails).\u001b[0m\n\n\u001b[90m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mWith a NAME and any --from-*\u001b[0m\u001b[38;2;247;250;252m flag, the value is copied from an existing store\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mcoordinate into the declaration's computed coordinate (like \u001b[0m\u001b[38;2;0;255;255;1mterraform import\u001b[0m\u001b[38;2;247;250;252m,\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mthe source is never modified or deleted). The --from-stack/--from-component\u001b[0m\n\u001b[90m\u001b[0m  \u001b[38;2;247;250;252mvalues\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mare raw path segments — typically transcribed from a legacy \u001b[0m\u001b[38;2;0;255;255;1m!store \u003cstore\u003e\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m  \u001b[38;2;0;255;255;1m\u003cstack\u003e \u003ccomponent\u003e \u003ckey\u003e\u001b[0m\u001b[38;2;247;250;252m expression — and need not name a real stack or\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mcomponent. --from-store defaults to the declaration's own store, --from-key to\u001b[0m\n\u001b[90m\u001b[0m  \u001b[38;2;247;250;252mthe\u001b[0m\n\u001b[90m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252msecret\u001b[0m\u001b[38;2;247;250;252m name.\u001b[0m\n\n\u001b[1;36mUSAGE\u001b[0m\n\n  \u001b[44m                                           \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44msecret\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mimport\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mFILE|NAME\u001b[0m\u001b[37;44m \u001b[0m\u001b[3;37;44m[flags]\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\n  \u001b[44m                                           \u001b[0m\n\n\u001b[1;36mEXAMPLES\u001b[0m\n\n  \u001b[44m                                                                                           \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Import secrets from a file. Each key is written to its OWN declared backend (the\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m     \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m  store or sops provider named in that secret's `secrets.vars` declaration); undeclared\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m  keys are warned about and skipped.\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                   \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44msecret\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mimport\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44m.env\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--stack=prod\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--component=api\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Preview what would be imported without writing\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44msecret\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mimport\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44m.env\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--stack=prod\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--component=api\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--dry-run\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                      \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m- Import from stdin\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                    \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                                       \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44mcat\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44m.env\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44m|\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44msecret\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mimport\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m-\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--stack=prod\u001b[0m\u001b[37;44m \u001b[0m\u001b[94;44m--component=api\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                        \u001b[0m\n  \u001b[44m                                                                                           \u001b[0m\n\n\u001b[1;36mFLAGS\u001b[0m\n\n  \u001b[1;36m    --dry-run\u001b[0m                \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPreview what would be imported without\u001b[0m\u001b[38;2;255;255;255m writing\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --format\u001b[0m \u001b[90mstring\u001b[0m          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mInput format: env or json (FILE mode only) (default \u001b[0m\u001b[38;2;155;81;224;1menv\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --from-component\u001b[0m \u001b[90mstring\u001b[0m  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mSource component path segment (raw; omit for stack-scoped source\u001b[0m\u001b[38;2;255;255;255m paths)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --from-key\u001b[0m \u001b[90mstring\u001b[0m        \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mSource key (default: the secret\u001b[0m\u001b[38;2;255;255;255m name)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --from-stack\u001b[0m \u001b[90mstring\u001b[0m      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mSource stack path segment (raw; need not be a real\u001b[0m\u001b[38;2;255;255;255m stack)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --from-store\u001b[0m \u001b[90mstring\u001b[0m      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mSource store to copy from (default: the declaration's own\u001b[0m\u001b[38;2;255;255;255m store)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-h, --help\u001b[0m                   \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mhelp for\u001b[0m\u001b[38;2;255;255;255m import\u001b[0m\u001b[0m\n\n\n\u001b[1;36mGLOBAL FLAGS\u001b[0m\n\n  \u001b[1;36m    --ai\u001b[0m                                   \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable AI-powered analysis of command\u001b[0m\u001b[38;2;255;255;255m output\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --base-path\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mBase path for Atmos\u001b[0m\u001b[38;2;255;255;255m project\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --cast\u001b[0m \u001b[90mstring\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mRecord command output as an asciinema cast (--cast for generated path,\u001b[0m\u001b[38;2;255;255;255m --\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mcast=path with a .cast, .gif, .mp4, .html, .ascii, .png, .jpg, or\u001b[0m\u001b[38;2;255;255;255m .jpeg\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mextension for explicit\u001b[0m\u001b[38;2;255;255;255m output)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-C, --chdir\u001b[0m \u001b[90mstring\u001b[0m                         \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mChange working directory before executing the command (run as if\u001b[0m\u001b[38;2;255;255;255m Atmos\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstarted in this\u001b[0m\u001b[38;2;255;255;255m directory)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-c, --component\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mAtmos\u001b[0m\u001b[38;2;255;255;255m component\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --config\u001b[0m \u001b[90mstrings\u001b[0m                       \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPaths to configuration files (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --config-path\u001b[0m \u001b[90mstrings\u0