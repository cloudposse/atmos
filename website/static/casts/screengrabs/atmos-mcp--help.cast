[0.002595666,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mManage MCP (Model Context Protocol) servers and external server\u001b[0m\u001b[38;2;247;250;252m connections.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAtmos MCP provides two\u001b[0m\u001b[38;2;247;250;252m capabilities:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mMCP Server\u001b[0m\u001b[38;2;247;250;252m — Exposes Atmos AI tools to AI assistants (Claude Desktop, Claude\u001b[0m\u001b[38;2;247;250;252m Code,\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mVSCode, Gemini CLI, Codex CLI) through the standardized MCP\u001b[0m\u001b[38;2;247;250;252m protocol.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mMCP Client\u001b[0m\u001b[38;2;247;250;252m — Connects to external MCP servers (AWS, GCP, Azure, custom)\u001b[0m\u001b[38;2;247;250;252m configured \u001b[0m\u001b[38;2;247;250;252min\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m  \u001b[38;2;0;255;255;1matmos.yaml\u001b[0m\u001b[38;2;247;250;252m under \u001b[0m\u001b[38;2;0;255;255;1mmcp.servers\u001b[0m\u001b[38;2;247;250;252m. Their tools become available in \u001b[0m\u001b[38;2;0;255;255;1matmos ai chat\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252mand \u001b[0m\u001b[38;2;0;255;255;1matmos\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m  \u001b[38;2;0;255;255;1mai exec\u001b[0m\u001b[38;2;247;250;252m alongside native Atmos\u001b[0m\u001b[38;2;247;250;252m tools.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mServer commands:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp start\u001b[0m\u001b[38;2;247;250;252m — Start the Atmos MCP\u001b[0m\u001b[38;2;247;250;252m server\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mClient commands:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp list\u001b[0m\u001b[38;2;247;250;252m — List configured external MCP\u001b[0m\u001b[38;2;247;250;252m servers\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp tools\u001b[0m\u001b[38;2;247;250;252m — List tools exposed by an MCP\u001b[0m\u001b[38;2;247;250;252m server\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp test\u001b[0m\u001b[38;2;247;250;252m — Test connectivity to an MCP\u001b[0m\u001b[38;2;247;250;252m server\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp status\u001b[0m\u001b[38;2;247;250;252m — Show status of all MCP\u001b[0m\u001b[38;2;247;250;252m servers\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1matmos mcp restart\u001b[0m\u001b[38;2;247;250;252m — Restart an MCP\u001b[0m\u001b[38;2;247;250;252m server\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u