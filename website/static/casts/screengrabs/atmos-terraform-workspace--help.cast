m  \u001b[38;2;247;250;252mselect\u001b[0m\u001b[38;2;247;250;252m it.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThis ensures that the workspace is properly set up for Terraform\u001b[0m\u001b[38;2;247;250;252m operations.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mFor complete Terraform/OpenTofu documentation,\u001b[0m\u001b[38;2;247;250;252m see:\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;0;163;224;4m\u001b[0m\u001b[38;2;0;163;224;4m\u001b[0m  \u001b[38;2;0;163;224;4mhttps://developer.hashicorp.com/terraform/cli/commands/workspace\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;0;163;224;4m\u001b[0m\u001b[38;2;0;163;224;4m\u001b[0m  \u001b[38;2;0;163;224;4mhttps://opentofu.org/docs/cli/commands/workspace\u001b[0m\n"]
