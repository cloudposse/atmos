38;5;231m[\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m        \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"name\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"list\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"description\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"List GitHub Actions cache entries over 1GB\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"env\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"arguments\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"flags\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"component_config\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;212m\"component\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;212m\"stack\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"\"\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"steps\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m[\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"command\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"echo \\\"Checking GitHub Actions cache for entries over 1GB...\\\"\\n\\nif ! command -v gh \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"GitHub CLI (gh) is not installed. Please install it first.\\\"\\n  echo \\\"Visit: https://cli.github.com/\\\"\\n  exit 1\\nfi\\n\\nif ! gh auth status \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"Not authenticated with GitHub. Please run: gh auth login\\\"\\n  exit 1\\nfi\\n\\nif ! gh actions-cache --help \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"Installing gh actions-cache extension...\\\"\\n  gh extension install actions/gh-actions-cache\\nfi\\n\\nCACHE_ENTRIES=$(gh actions-cache list -R cloudposse/atmos | grep GB)\\n\\nif [ -z \\\"$CACHE_ENTRIES\\\" ]; then\\n  echo \\\"No cache entries over 1GB found.\\\"\\n  exit 0\\nfi\\n\\necho \\\"Found cache entries over 1GB:\\\"\\necho \\\"\\\"\\necho \\\"$CACHE_ENTRIES\\\" | column -t -s \\\"$(printf '\\\\t')\\\"\\necho \\\"\\\"\\n\\nTOTAL_SIZE=$(echo \\\"$CACHE_ENTRIES\\\" | awk '{print $2}' | grep -o '[0-9.]*' | awk '{s+=$1} END {printf \\\"%.2f\\\", s}')\\nENTRY_COUNT=$(echo \\\"$CACHE_ENTRIES\\\" | wc -l | xargs)\\nUNIQUE_KEY_COUNT=$(echo \\\"$CACHE_ENTRIES\\\" | awk '{print $1}' | sort -u | wc -l | xargs)\\n\\necho \\\"Summary:\\\"\\necho \\\"  Total entries: $ENTRY_COUNT\\\"\\necho \\\"  Unique keys: $UNIQUE_KEY_COUNT\\\"\\necho \\\"  Total size: ${TOTAL_SIZE} GB\\\"\\necho \\\"\\\"\\necho \\\"Note: Each key may have multiple entries across different branches.\\\"\\necho \\\"To delete these caches, run: atmos cache clear\\\"\\n\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"type\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"shell\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"when\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;231m]\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"commands\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"verbose\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mfalse\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m        \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m        \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"name\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"clear\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"description\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"Clear GitHub Actions cache entries over 1GB\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"env\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"arguments\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"flags\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"component_config\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;212m\"component\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;212m\"stack\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"\"\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"steps\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m[\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"command\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"echo \\\"Checking GitHub Actions cache for entries over 1GB...\\\"\\n\\nif ! command -v gh \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"GitHub CLI (gh) is not installed. Please install it first.\\\"\\n  echo \\\"Visit: https://cli.github.com/\\\"\\n  exit 1\\nfi\\n\\nif ! gh auth status \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"Not authenticated with GitHub. Please run: gh auth login\\\"\\n  exit 1\\nfi\\n\\nif ! gh actions-cache --help \u003e/dev/null 2\u003e\u00261; then\\n  echo \\\"Installing gh actions-cache extension...\\\"\\n  gh extension install actions/gh-actions-cache\\nfi\\n\\nCACHE_ENTRIES=$(gh actions-cache list -R cloudposse/atmos | grep GB)\\n\\nif [ -z \\\"$CACHE_ENTRIES\\\" ]; then\\n  echo \\\"No cache entries over 1GB found.\\\"\\n  exit 0\\nfi\\n\\necho \\\"Found cache entries over 1GB:\\\"\\necho \\\"$CACHE_ENTRIES\\\"\\necho \\\"\\\"\\n\\nENTRY_COUNT=$(echo \\\"$CACHE_ENTRIES\\\" | wc -l | xargs)\\necho \\\"Total entries to delete: $ENTRY_COUNT\\\"\\necho \\\"\\\"\\n\\nprintf \\\"Do you want to delete these cache entries? (y/N): \\\"\\nread -r REPLY\\n\\ncase \\\"$REPLY\\\" in\\n  [Yy]) ;;\\n  *)\\n    echo \\\"Cancelled.\\\"\\n    exit 0\\n    ;;\\nesac\\n\\necho \\\"Deleting cache entries...\\\"\\necho \\\"Note: Each key may match multiple cache entries across different branches.\\\"\\necho \\\"\\\"\\n\\nFAILED_KEYS=0\\nSUCCESS_KEYS=0\\nTOTAL_DELETED=0\\n\\nUNIQUE_KEYS=$(echo \\\"$CACHE_ENTRIES\\\" | awk '{print $1}' | sort -u)\\nUNIQUE_KEY_COUNT=$(echo \\\"$UNIQUE_KEYS\\\" | wc -l | xargs)\\nUNIQUE_KEYS_FILE=$(mktemp)\\nFAILED_LIST_FILE=$(mktemp)\\ntrap 'rm -f \\\"$UNIQUE_KEYS_FILE\\\" \\\"$FAILED_LIST_FILE\\\"' EXIT INT TERM\\nprintf '%s\\\\n' \\\"$UNIQUE_KEYS\\\" \u003e \\\"$UNIQUE_KEYS_FILE\\\"\\n\\necho \\\"Found $UNIQUE_KEY_COUNT unique cache key(s) to process\\\"\\necho \\\"\\\"\\n\\nwhile read -r cache_key; do\\n  if [ -n \\\"$cache_key\\\" ]; then\\n    short_key=$(printf '%.50s' \\\"$cache_key\\\")\\n    echo \\\"Processing key: ${short_key}...\\\"\\n\\n    DELETE_OUTPUT=$(gh actions-cache delete \\\"$cache_key\\\" -R cloudposse/atmos --confirm 2\u003e\u00261)\\n    DELETE_EXIT=$?\\n\\n    if [ $DELETE_EXIT -eq 0 ]; then\\n      DELETED_COUNT=$(echo \\\"$DELETE_OUTPUT\\\" | grep -oE \\\"Deleted [0-9]+ cache\\\" | grep -oE \\\"[0-9]+\\\" || echo \\\"1\\\")\\n      echo \\\"$DELETE_OUTPUT\\\" | head -1\\n      echo \\\"Successfully processed key\\\"\\n      SUCCESS_KEYS=$((SUCCESS_KEYS + 1))\\n      TOTAL_DELETED=$((TOTAL_DELETED + DELETED_COUNT))\\n    else\\n      echo \\\"Failed to delete key\\\"\\n      FAILED_KEYS=$((FAILED_KEYS + 1))\\n      printf '    %s...\\\\n' \\\"$short_key\\\" \u003e\u003e \\\"$FAILED_LIST_FILE\\\"\\n    fi\\n  fi\\ndone \u003c \\\"$UNIQUE_KEYS_FILE\\\"\\n\\necho \\\"\\\"\\nif [ \\\"$FAILED_KEYS\\\" -eq 0 ] \u0026\u0026 [ \\\"$SUCCESS_KEYS\\\" -gt 0 ]; then\\n  echo \\\"Cache cleanup complete.\\\"\\n  echo \\\"Processed $SUCCESS_KEYS unique key(s)\\\"\\n  echo \\\"Total cache entries deleted: $TOTAL_DELETED\\\"\\nelif [ \\\"$SUCCESS_KEYS\\\" -eq 0 ] \u0026\u0026 [ \\\"$FAILED_KEYS\\\" -gt 0 ]; then\\n  echo \\\"Cache cleanup failed. Could not delete any keys.\\\"\\n  echo \\\"\\\"\\n  echo \\\"Failed keys:\\\"\\n  cat \\\"$FAILED_LIST_FILE\\\"\\n  echo \\\"\\\"\\n  echo \\\"Try:\\\"\\n  echo \\\"  1. Update gh CLI: brew upgrade gh\\\"\\n  echo \\\"  2. Re-authenticate: gh auth refresh\\\"\\n  echo \\\"  3. Delete manually: gh actions-cache delete \u003ckey\u003e -R cloudposse/atmos --confirm\\\"\\nelse\\n  echo \\\"Cache cleanup finished with mixed results.\\\"\\n  echo \\\"Successful keys: $SUCCESS_KEYS\\\"\\n  echo \\\"Failed keys: $FAILED_KEYS\\\"\\n  echo \\\"Total cache entries deleted: $TOTAL_DELETED\\\"\\n  if [ -s \\\"$FAILED_LIST_FILE\\\" ]; then\\n    echo \\\"\\\"\\n    echo \\\"Failed keys:\\\"\\n    cat \\\"$FAILED_LIST_FILE\\\"\\n  fi\\n  echo \\\"\\\"\\n  echo \\\"For failed keys, try updating gh CLI: brew upgrade gh\\\"\\nfi\\n\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"type\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;228m\"shell\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m              \u001b[0m\u001b[38;5;212m\"when\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;212mnull\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m            \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;231m]\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;5;231m          \u001b[0m\u001b[38;5;212m\"commands\"\u001b[0m\u001b[38;5;231m:\