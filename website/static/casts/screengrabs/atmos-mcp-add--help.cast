r and immediately install it into detected AI clients.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add \u001b[0m\u001b[38;5;72m\"uvx awslabs.aws-documentation-mcp-server@latest\"\u001b[0m\u001b[38;5;231m --install\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add a server with an explicit name, description, and Atmos Auth identity.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add uvx --name aws-docs --description \u001b[0m\u001b[38;5;72m\"AWS Documentation\"\u001b[0m\u001b[38;5;231m --identity\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;5;51m\u001b[0m  \u001b[38;5;51mreadonly\u001b[0m\u001b[38;5;231m\u001b[0m\n"]
