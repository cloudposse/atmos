[0.003669208,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAdd an MCP server to \u001b[0m\u001b[38;2;0;255;255;1mmcp.servers\u001b[0m\u001b[38;2;247;250;252m in \u001b[0m\u001b[38;2;0;255;255;1matmos.yaml\u001b[0m\u001b[38;2;247;250;252m without hand-editing\u001b[0m\u001b[38;2;247;250;252m YAML.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe target can be a built-in preset (\u001b[0m\u001b[38;2;0;255;255;1mself\u001b[0m\u001b[38;2;247;250;252m for Atmos's own MCP server, \u001b[0m\u001b[38;2;0;255;255;1matmos-pro\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252mfor\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m  \u001b[38;2;247;250;252mthe\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAtmos Pro MCP server), an \u001b[0m\u001b[38;2;0;255;255;1mhttp(s)://\u001b[0m\u001b[38;2;247;250;252m URL, or a local stdio command.\u001b[0m\u001b[38;2;247;250;252m Only \u001b[0m\u001b[38;2;0;255;255;1matmos.yaml\u001b[0m\u001b[38;2;247;250;252m is\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mwritten by default — use \u001b[0m\u001b[38;2;0;255;255;1m--install\u001b[0m\u001b[38;2;247;250;252m to also push the new\u001b[0m\u001b[38;2;247;250;252m server \u001b[0m\u001b[38;2;247;250;252minto your AI client's\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mconfig in the same step, or run \u001b[0m\u001b[38;2;0;255;255;1matmos mcp install\u001b[0m\u001b[38;2;247;250;252m separately.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mExamples:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add Atmos's own MCP server (also the default target with no argument).\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add self\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add the Atmos Pro MCP server.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add atmos-pro\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add a remote HTTP server with an auth header.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add https://mcp.example.com/mcp --header \u001b[0m\u001b[38;5;72m\"Authorization: Bearer \u001b[0m\u001b[38;5;72m${\u001b[0m\u001b[38;5;231mTOKEN\u001b[0m\u001b[38;5;72m}\u001b[0m\u001b[38;5;72m\"\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add a local stdio server and immediately install it into detected AI clients.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add \u001b[0m\u001b[38;5;72m\"uvx awslabs.aws-documentation-mcp-server@latest\"\u001b[0m\u001b[38;5;231m --install\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Add a server with an explicit name, description, and Atmos Auth identity.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp add uvx --name aws-docs --description \u001b[0m\u001b[38;5;72m\"AWS Documentation\"\u001b[0m\u001b[38;5;231m --identity\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;5;51m\u001b[0m  \u001b[38;5;51mreadonly\u001b[0m\u001b[38;5;231m\u001b[0m\n"]
