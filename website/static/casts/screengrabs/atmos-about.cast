[0.003031208,"o","\u001b[38;2;26;32;44;48;2;0;163;224;1m\u001b[0m\u001b[38;2;26;32;44;48;2;0;163;224;1m\u001b[0m  \u001b[38;2;26;32;44;48;2;0;163;224;1m \u001b[0m\u001b[38;2;247;250;252;48;2;0;163;224;1mAbout\u001b[0m\u001b[38;2;247;250;252;48;2;0;163;224;1m Atmos\u001b[0m\u001b[38;2;26;32;44;48;2;0;163;224;1m \u001b[0m\n\u001b[0m  \n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAtmos is an open-source framework for managing the configuration of Infrastructure as\n\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mCode (IaC) at scale using\u001b[0m\u001b[38;2;247;250;252m Stacks.\u001b[0m\n  \n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mIt simplifies the deployment of infrastructure by providing a consistent, YAML-driven\n\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mconfiguration system using\u001b[0m\u001b[38;2;247;250;252m tools \u001b[0m\u001b[38;2;247;250;252mlike Terraform, OpenTofu, Helmfile, and\u001b[0m\u001b[38;2;247;250;252m Packer. \u001b[0m\u001b[38;2;247;250;252mAtmos\u001b[0m\n\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mhelps teams adopt best practices, enforce standards, and automate complex workflows\n\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252macross\u001b[0m\u001b[38;2;247;250;252m environments.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m  \n\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1m## \u001b[0m\u001b[38;2;247;250;252;1mKey\u001b[0m\u001b[38;2;247;250;252;1m Features\u001b[0m\n\u001b[0m  \n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mReusable Components\u001b[0m\u001b[38;2;247;250;252m: Modular building blocks for defining\u001b[0m\u001b[38;2;247;250;252m infrastructure.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mStacks\u001b[0m\u001b[38;2;247;250;252m: Environment-specific configurations for managing multiple cloud\u001b[0m\u001b[38;2;247;250;252m accounts.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mYAML-Based\u001b[0m\u001b[38;2;247;250;252m: Declarative configurations for easy\u001b[0m\u001b[38;2;247;250;252m maintenance.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mTerraform, OpenTofu, Helmfile, Packer\u001b[0m\u001b[38;2;247;250;252m: Unified commands for seamless\u001b[0m\u001b[38;2;247;250;252m integration.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mAutomation-Ready\u001b[0m\u001b[38;2;247;250;252m: Perfect for CI/CD pipelines and DevOps\u001b[0m\u001b[38;2;247;250;252m workflows.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;155;81;224;1mScalable\u001b[0m\u001b[38;2;247;250;252m: Designed for multi-account, multi-environment\u001b[0m\u001b[38;2;247;250;252m setups.\u001b[0m\n\u001b[38;2;247;250;252m\u001b[0m  \n\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1m## \u001b[0m\u001b[38;2;247;250;252;1mWhy\u001b[0m\u001b[38;2;247;250;252;1m Atmos?\u001b[0m\n\u001b[0m  \n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mAtmos reduces complexity, promotes consistency, and accelerates delivery, making it an\u001b[0m\n\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mideal\u001b[0m\u001b[38;2;247;250;252m choice \u001b[0m\u001b[38;2;247;250;252mfor organizations managing large-scale cloud\u001b[0m\u001b[38;2;247;250;252m infrastructure.\u001b[0m\n  \n\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mLearn more \u001b[0m\u001b[38;2;155;81;224;1mhere\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;0;163;224;4mhttps://atmos.tools\u001b[0m\n\n"]
