;255;255m(requires TTY, disabled in CI) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-file\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mThe file to write Atmos logs to. Logs can be written to any file or\u001b[0m\u001b[38;2;255;255;255m any\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstandard file descriptor, including '/dev/stdout', '/dev/stderr'\u001b[0m\u001b[38;2;255;255;255m and\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m'/dev/null' (default \u001b[0m\u001b[38;2;155;81;224;1m/dev/stderr\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-level\u001b[0m \u001b[90mstring\u001b[0m                    \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mLogs level. Supported log levels are Trace, Debug, Info, Warning, Off.\u001b[0m\u001b[38;2;255;255;255m If\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mthe log level is set to Off, Atmos will not log any messages \u001b[0m\u001b[38;2;255;255;255m(default\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;155;81;224;1mWarning\u001b[0m\u001b[38;2;255;255;25