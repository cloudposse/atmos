[0.011522625,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mStart an MCP server that exposes Atmos AI tools via the Model Context\u001b[0m\u001b[38;2;247;250;252m Protocol.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe server allows AI assistants to access Atmos infrastructure management\u001b[0m\u001b[38;2;247;250;252m capabilities\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mincluding component descriptions, stack listings, configuration validation, and\u001b[0m\u001b[38;2;247;250;252m file\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252moperations.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mSupported transports:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1mstdio\u001b[0m\u001b[38;2;247;250;252m (default) — For desktop clients like Claude Desktop and Claude\u001b[0m\u001b[38;2;247;250;252m Code\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1mhttp\u001b[0m\u001b[38;2;247;250;252m — HTTP with Server-Sent Events (SSE) for remote or cloud\u001b[0m\u001b[38;2;247;250;252m clients\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mConfiguration:\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252mRequires \u001b[0m\u001b[38;2;0;255;255;1mmcp.enabled: true\u001b[0m\u001b[38;2;247;250;252m and \u001b[0m\u001b[38;2;0;255;255;1mai.enabled: true\u001b[0m\u001b[38;2;247;250;252m with \u001b[0m\u001b[38;2;0;255;255;1mai.tools.enabled:\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;0;255;255;1m\u001b[0m  \u001b[38;2;0;255;255;1mtrue\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252min \u001b[0m\u001b[38;2;0;255;255;1matmos.yaml\u001b[0m\u001b[38;2;247;250;252m. Stack manifests are loaded lazily by stack-dependent tools,\u001b[0m\u001b[38;2;247;250;252m so \u001b[0m\u001b[38;2;247;250;252mthe\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mMCP server can start before stacks exist or while stack imports are\u001b[0m\u001b[38;2;247;250;252m being \u001b[0m\u001b[38;2;247;250;252mfixed.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe server runs until interrupted (Ctrl+C) or the client\u001b[0m\u001b[38;2;247;250;252m disconnects.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mExamples:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with stdio transport (default, for Claude Desktop).\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with HTTP transport on custom port.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start --transport http --port \u001b[0m\u001b[38;5;51m9090\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with HTTP on specific host.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start --transport http --host 0.0.0.0 --port \u001b[0m\u001b[38;5;51m8080\u001b[0m\u001b[38;5;231m\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mClaude Desktop configuration (claude_\u001b[0m\u001b[38;2;155;81;224;1mdesktop_\u001b[0m\u001b[38;2;155;81;224;1mconfig.json):\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m  \u001b[0m\u001b[38;5;203m\"mcpServers\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m    \u001b[0m\u001b[38;5;203m\"atmos\"\u001b[0m\u001b[38;5;231m:\u