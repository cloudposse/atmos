1m\u001b[0m  \u001b[38;2;155;81;224;1mExamples:\u001b[0m\n\n\u001b[90m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with stdio transport (default, for Claude Desktop).\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with HTTP transport on custom port.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start --transport http --port \u001b[0m\u001b[38;5;51m9090\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;240m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;240m# Start with HTTP on specific host.\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231matmos mcp start --transport http --host 0.0.0.0 --port \u001b[0m\u001b[38;5;51m8080\u001b[0m\u001b[38;5;231m\u001b[0m\n\n\u001b[90m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mClaude Desktop configuration (claude_\u001b[0m\u001b[38;2;155;81;224;1mdesktop_\u001b[0m\u001b[38;2;155;81;224;1mconfig.json):\u001b[0m\n\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m  \u001b[0m\u001b[38;5;203m\"mcpServers\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m    \u001b[0m\u001b[38;5;203m\"atmos\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m{\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m      \u001b[0m\u001b[38;5;203m\"command\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;72m\"atmos\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m      \u001b[0m\u001b[38;5;203m\"args\"\u001b[0m\u001b[38;5;231m:\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;231m[\u001b[0m\u001b[38;5;72m\"mcp\"\u001b[0m\u001b[38;5;231m,\u001b[0m\u001b[38;5;231m \u001b[0m\u001b[38;5;72m\"start\"\u001b[0m\u001b[38;5;231m]\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m    \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m  \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m\u001b[0m\n\u001b[90m\u001b[38;5;231m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;5;231m}\u001b[0m\u001b[38;5;231m\u001b[0m\n\n\u001b[1;36mUSAGE\u001b[0m\n\n  \u001b[44m                             \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m$ \u001b[0m\u001b[1;94;44matmos\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mmcp\u001b[0m\u001b[37;44m \u001b[0m\u001b[37;44mstart\u001b[0m\u001b[37;44m \u001b[0m\u001b[3;37;44m[flags]\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\n  \u001b[44m                             \u001b[0m\n\n\u001b[1;36mEXAMPLES\u001b[0m\n\n  \u001b[44m                                                                          \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m# Start MCP server with stdio transport (default, for desktop clients)\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m  atmos mcp start\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                     \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                      \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m  # Start MCP server with HTTP transport\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                              \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m  atmos mcp start --transport http --port 8080\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                        \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                                                                      \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[90;44m  # Start HTTP server on custom host and port\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m                         \u001b[0m\n  \u001b[44m  \u001b[0m\u001b[37;44m\u001b[37;44m  atmos mcp start --transport http --host 127.0.0.1 --port 3000\u001b[0m\u001b[0m\u001b[44m  \u001b[0m\u001b[44m       \u001b[0m\n  \u001b[44m                                                                          \u001b[0m\n\n\u001b[1;36mFLAGS\u001b[0m\n\n  \u001b[1;36m-h, --help\u001b[0m              \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mhelp for\u001b[0m\u001b[38;2;255;255;255m start\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --host\u001b[0m \u001b[90mstring\u001b[0m       \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mHost to bind HTTP server (only for http transport) (default \u001b[0m\u001b[38;2;155;81;224;1mlocalhost\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --port\u001b[0m \u001b[90mint\u001b[0m          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPort to bind HTTP server (only for http transport) (default \u001b[0m\u001b[38;2;155;81;224;1m8080\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --transport\u001b[0m \u001b[90mstring\u001b[0m  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mTransport type: stdio or http (default \u001b[0m\u001b[38;2;155;81;224;1mstdio\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n\n\u001b[1;36mGLOBAL FLAGS\u001b[0m\n\n  \u001b[1;36m    --ai\u001b[0m                                   \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable AI-powered analysis of command\u001b[0m\u001b[38;2;255;255;255m output\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --base-path\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mBase path for Atmos\u001b[0m\u001b[38;2;255;255;255m project\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --cast\u001b[0m \u001b[90mstring\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mRecord command output as an asciinema cast (--cast for generated path,\u001b[0m\u001b[38;2;255;255;255m --\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mcast=path with a .cast, .gif, .mp4, .html, .ascii, .png, .jpg, or\u001b[0m\u001b[38;2;255;255;255m .jpeg\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mextension for explicit\u001b[0m\u001b[38;2;255;255;255m output)\u001b[0m\u001b[0m\n\n  \u001b[1;36m-C, --chdir\u001b[0m \u001b[90mstring\u001b[0m                         \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mChange working directory before executing the command (run as if\u001b[0m\u001b[38;2;255;255;255m Atmos\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstarted in this\u001b[0m\u001b[38;2;255;255;255m directory)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --config\u001b[0m \u001b[90mstrings\u001b[0m                       \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPaths to configuration files (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --config-path\u001b[0m \u001b[90mstrings\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mPaths to search for Atmos configuration (comma-separated or repeated\u001b[0m\u001b[38;2;255;255;255m flag)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --force-color\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mForce color output even when not a TTY (useful for\u001b[0m\u001b[38;2;255;255;255m screenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --force-tty\u001b[0m                            \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mForce TTY mode with sane defaults when terminal detection fails \u001b[0m\u001b[38;2;255;255;255m(useful\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mfor\u001b[0m\u001b[38;2;255;255;255m screenshots)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap\u001b[0m                              \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mShow performance heatmap visualization after command execution \u001b[0m\u001b[38;2;255;255;255m(includes\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mP95\u001b[0m\u001b[38;2;255;255;255m latency)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --heatmap-mode\u001b[0m \u001b[90mstring\u001b[0m                  \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mHeatmap visualization mode: bar, sparkline, table (press 1-3 to switch\u001b[0m\u001b[38;2;255;255;255m in\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mTUI) (default \u001b[0m\u001b[38;2;155;81;224;1mbar\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --identity\u001b[0m \u001b[90mstring\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mIdentity to use for authentication. Use --identity to select interactively,\u001b[0m\u001b[38;2;255;255;255m --\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255midentity=NAME to\u001b[0m\u001b[38;2;255;255;255m specify\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --interactive\u001b[0m                          \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable interactive prompts for missing required flags, optional\u001b[0m\u001b[38;2;255;255;255m value\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mflags using the sentinel pattern, and missing positional\u001b[0m\u001b[38;2;255;255;255m arguments\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m(requires TTY, disabled in CI) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-file\u001b[0m \u001b[90mstring\u001b[0m                     \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mThe file to write Atmos logs to. Logs can be written to any file or\u001b[0m\u001b[38;2;255;255;255m any\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mstandard file descriptor, including '/dev/stdout', '/dev/stderr'\u001b[0m\u001b[38;2;255;255;255m and\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255m'/dev/null' (default \u001b[0m\u001b[38;2;155;81;224;1m/dev/stderr\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --logs-level\u001b[0m \u001b[90mstring\u001b[0m                    \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mLogs level. Supported log levels are Trace, Debug, Info, Warning, Off.\u001b[0m\u001b[38;2;255;255;255m If\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mthe log level is set to Off, Atmos will not log any messages \u001b[0m\u001b[38;2;255;255;255m(default\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;155;81;224;1mWarning\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --mask\u001b[0m                                 \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable automatic masking of sensitive data in output (use --mask=false\u001b[0m\u001b[38;2;255;255;255m to\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mdisable) (default \u001b[0m\u001b[38;2;155;81;224;1mtrue\u001b[0m\u001b[38;2;255;255;255m)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --no-color\u001b[0m                             \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mDisable color\u001b[0m\u001b[38;2;255;255;255m output\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --pager\u001b[0m \u001b[90mstring\u001b[0m                         \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mEnable pager for output (--pager or --pager=true to enable, --pager=false\u001b[0m\u001b[38;2;255;255;255m to\u001b[0m\u001b[0m\n                                             \u001b[97m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m\u001b[38;2;255;255;255m\u001b[0m  \u001b[38;2;255;255;255m \u001b[0m\u001b[38;2;255;255;255mdisable, --pager=less to use specific\u001b[0m\u001b[38;2;255;255;255m pager)\u001b[0m\u001b[0m\n\n  \u001b[1;36m    --profile\u001b[0m \u001b[90mstrings\u001b[0m                      \u001b[97m\u001b[38;2;255;255;255m\u001b[0m\u0