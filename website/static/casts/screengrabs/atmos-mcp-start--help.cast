[0.003798666,"o","\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mStart an MCP server that exposes Atmos AI tools via the Model Context\u001b[0m\u001b[38;2;247;250;252m Protocol.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mThe server allows AI assistants to access Atmos infrastructure management\u001b[0m\u001b[38;2;247;250;252m capabilities\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252mincluding component descriptions, stack listings, configuration validation, and\u001b[0m\u001b[38;2;247;250;252m file\u001b[0m\n\u001b[38;2;73;85;104m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252moperations.\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mSupported transports:\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1mstdio\u001b[0m\u001b[38;2;247;250;252m (default) — For desktop clients like Claude Desktop and Claude\u001b[0m\u001b[38;2;247;250;252m Code\u001b[0m\n\u001b[38;2;73;85;104m\u001b[38;2;247;250;252m\u001b[0m\u001b[38;2;247;250;252m\u001b[0m  \u001b[38;2;247;250;252m• \u001b[0m\u001b[38;2;0;255;255;1mhttp\u001b[0m\u001b[38;2;247;250;252m — HTTP with Server-Sent Events (SSE) for remote or cloud\u001b[0m\u001b[38;2;247;250;252m clients\u001b[0m\n\n\u001b[38;2;73;85;104m\u001b[38;2;155;81;224;1m\u001b[0m\u001b[38;2;155;81;224;1m\u001b[0m  \u001b[38;2;155;81;224;1mConfiguration:\u001b[0m\u001b[38;2;247;250;252m \u001b[0m\u001b[38;2;247;250;252mRequires \u001b[0m\u001b[38;2;0;255;255;1mmcp.enabled: true\u001b[0m\u001b[38;2;247;250;252m and \u001b[0m\u001b[38;2;0;255;255;1mai.enabled: true\u001b[0m\