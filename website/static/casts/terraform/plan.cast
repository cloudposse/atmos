[0.47303675,"o","\r\n\u001b[1m  # null_resource.vpc\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"null_resource\" \"vpc\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m triggers = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"cidr_block\"           = \"10.0.0.0/16\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"enable_dns_hostnames\" = \"true\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"environment\"          = \"dev\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"tags\"                 = jsonencode(\r\n                {\r\n                  \u001b[32m+\u001b[0m\u001b[0m Environment = \"Development\"\r\n                  \u001b[32m+\u001b[0m\u001b[0m Team        = \"platform\"\r\n                }\r\n            )\r\n        }\r\n    }\r\n\r\n\u001b[1mPlan:\u001b[0m \u001b[0m1 to add, 0 to change, 0 to destroy.\r\n\r\nChanges to Outputs:\r\n  \u001b[32m+\u001b[0m\u001b[0m environment = \"dev\"\r\n  \u001b[32m+\u001b[0m\u001b[0m vpc_cidr    = \"10.0.0.0/16\"\r\n"]
