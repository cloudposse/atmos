{
  "$id": "s3-bucket-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "s3-bucket component validation",
  "description": "JSON Schema for the 's3-bucket' Atmos component.",
  "type": "object",
  "properties": {
    "vars": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 40,
          "pattern": "^[a-z0-9-]+$"
        },
        "versioning_enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true,
      "required": [
        "name",
        "versioning_enabled"
      ]
    }
  }
}
