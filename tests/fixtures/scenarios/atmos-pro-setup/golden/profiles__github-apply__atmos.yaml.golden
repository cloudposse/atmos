auth:
  providers:
    github-oidc:
      kind: github/oidc
      region: us-east-1
      spec:
        audience: sts.amazonaws.com

  # The name of each identity matches the pattern <tenant>-<stage>/<role>.
  # Atmos resolves these names per-stack at plan/apply time.
  #
  # github-apply uses gha-tf-apply roles for full (terraform apply) access.
  # Root account is pinned to the plan role as a safety rail -- automation
  # must never apply to the root account.
  identities:
    gov-root/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        # Safety: assumes gha-tf-plan (read-only) to prevent automation from applying to the root account.
        assume_role: arn:aws:iam::111111111111:role/ex-gov-gbl-root-gha-tf-plan
    gov-iam/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::222222222222:role/ex-gov-gbl-iam-gha-tf-apply
    gov-dss/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::333333333333:role/ex-gov-gbl-dss-gha-tf-apply
    soc-clip/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::444444444444:role/ex-soc-gbl-clip-gha-tf-apply
    soc-siem/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::555555555555:role/ex-soc-gbl-siem-gha-tf-apply
    soc-wksn/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::666666666666:role/ex-soc-gbl-wksn-gha-tf-apply
