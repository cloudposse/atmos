auth:
  providers:
    github-oidc:
      kind: github/oidc
      region: us-east-1
      spec:
        audience: sts.amazonaws.com

  # The name of each identity matches the pattern <tenant>-<stage>/<role>.
  # Atmos resolves these names per-stack at plan/apply time.
  #
  # github-apply uses gha-tf-apply roles for full (terraform apply) access.
  # Root account is pinned to the plan role as a safety rail -- automation
  # must never apply to the root account.
  identities:
    core-root/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        # Safety: assumes gha-tf-plan (read-only) to prevent automation from applying to the root account.
        assume_role: arn:aws:iam::111111111111:role/ex-core-gbl-root-gha-tf-plan
    core-identity/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::222222222222:role/ex-core-gbl-identity-gha-tf-apply
    core-audit/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::333333333333:role/ex-core-gbl-audit-gha-tf-apply
    plat-dev/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::444444444444:role/ex-plat-gbl-dev-gha-tf-apply
    plat-staging/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::555555555555:role/ex-plat-gbl-staging-gha-tf-apply
    plat-prod/gha-tf-apply:
      kind: aws/assume-role
      via:
        provider: github-oidc
      principal:
        assume_role: arn:aws:iam::666666666666:role/ex-plat-gbl-prod-gha-tf-apply
