# Variables for {{ .Config.project_name }}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "{{ .Config.environment | replace `"` `\"` | replace `${` `$${` }}"
}

variable "project_name" {
  description = "Project name"
  type        = string
  default     = "{{ .Config.project_name | replace `"` `\"` | replace `${` `$${` }}"
}

variable "author" {
  description = "Author name"
  type        = string
  default     = "{{ .Config.author | replace `"` `\"` | replace `${` `$${` }}"
}
