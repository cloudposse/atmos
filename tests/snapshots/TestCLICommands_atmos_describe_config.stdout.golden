    "base_path": "stacks",
    "included_paths": [
      "deploy/**/*"
    ],
    "excluded_paths": [
      "**/_defaults.yaml"
    ],
    "name_pattern": "",
    "name_template": "{{ .vars.stage }}",
    "list": {
      "format": "",
