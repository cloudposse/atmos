component_type: terraform
deps:
  - catalog/mock/defaults
  - mixins/stage/dev
  - orgs/acme/_defaults
  - orgs/acme/dev/us-east-1
deps_all:
  - catalog/mock/defaults
  - mixins/stage/dev
  - orgs/acme/_defaults
  - orgs/acme/dev/us-east-1
env: {}
generate: {}
hooks: {}
imports:
  - catalog/mock/defaults
  - mixins/stage/dev
  - orgs/acme/_defaults
inheritance: []
metadata:
  component: mock
overrides: {}
providers: {}
provision: {}
remote_state_backend: {}
remote_state_backend_type: ""
required_providers: {}
required_version: ""
settings: {}
source: {}
sources:
  backend: {}
  env: {}
  settings: {}
  vars:
    enabled:
      final_value: true
      name: enabled
      stack_dependencies:
        - dependency_type: import
          stack_file: catalog/mock/defaults
          stack_file_section: components.terraform.vars
          variable_value: true
    environment:
      final_value: development
      name: environment
      stack_dependencies:
        - dependency_type: import
          stack_file: mixins/stage/dev
          stack_file_section: components.terraform.vars
          variable_value: development
        - dependency_type: import
          stack_file: mixins/stage/dev
          stack_file_section: vars
          variable_value: development
    name:
      final_value: mock
      name: name
      stack_dependencies:
        - dependency_type: import
          stack_file: catalog/mock/defaults
          stack_file_section: components.terraform.vars
          variable_value: mock
    namespace:
      final_value: acme
      name: namespace
      stack_dependencies:
        - dependency_type: import
          stack_file: orgs/acme/_defaults
          stack_file_section: vars
          variable_value: acme
    region:
      final_value: us-east-1
      name: region
      stack_dependencies:
        - dependency_type: inline
          stack_file: orgs/acme/dev/us-east-1
          stack_file_section: components.terraform.vars
          variable_value: us-east-1
        - dependency_type: inline
          stack_file: orgs/acme/dev/us-east-1
          stack_file_section: vars
          variable_value: us-east-1
    stage:
      final_value: dev
      name: stage
      stack_dependencies:
        - dependency_type: import
          stack_file: mixins/stage/dev
          stack_file_section: vars
          variable_value: dev
    tags:
      final_value:
        managed_by: atmos
        region: us-east-1
        stage: dev
        tenant: acme
      name: tags
      stack_dependencies:
        - dependency_type: inline
          stack_file: orgs/acme/dev/us-east-1
          stack_file_section: components.terraform.vars
          variable_value:
            region: us-east-1
        - dependency_type: import
          stack_file: catalog/mock/defaults
          stack_file_section: components.terraform.vars
          variable_value:
            managed_by: atmos
        - dependency_type: import
          stack_file: mixins/stage/dev
          stack_file_section: components.terraform.vars
          variable_value:
            stage: dev
        - dependency_type: import
          stack_file: orgs/acme/_defaults
          stack_file_section: components.terraform.vars
          variable_value:
            tenant: acme
    tenant:
      final_value: acme
      name: tenant
      stack_dependencies:
        - dependency_type: import
          stack_file: orgs/acme/_defaults
          stack_file_section: vars
          variable_value: acme
stack: acme-dev-us-east-1
tf_cli_vars: {}
