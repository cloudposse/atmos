atmos_cli_config:
  base_path: .
  components:
    terraform:
      base_path: ../../components/terraform
      apply_auto_approve: false
      append_user_agent: Atmos/test (Cloud Posse; +https://atmos.tools)
      deploy_run_init: false
      init_run_reconfigure: false
      auto_generate_backend_file: false
      auto_generate_files: false
      command: tofu
      shell:
        prompt: ""
      init:
        pass_vars: false
      plan:
        skip_planfile: false
      plugin_cache: true
      auto_provision_workdir_for_outputs: true
    helmfile:
      base_path: ""
      use_eks: true
      kubeconfig_path: ""
      helm_aws_profile_pattern: ""
      cluster_name_pattern: ""
      cluster_name_template: ""
      cluster_name: ""
      command: ""
      auto_generate_files: false
    packer:
      base_path: ""
      command: ""
      auto_generate_files: false
    ansible:
      base_path: ""
      command: ""
      auto_generate_files: false
  stacks:
    base_path: stacks
    included_paths:
      - orgs/**/*
    excluded_paths:
      - '**/_defaults.yaml'
    name_pattern: ""
    name_template: '{{ .vars.tenant }}-{{ .vars.stage }}-{{ .vars.region }}'
  workflows:
    base_path: ""
    list:
      format: ""
      columns: []
atmos_component: mock
